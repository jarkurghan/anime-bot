{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "types": ["bun", "node"]
    },
    "include": ["index.ts", "load-env.ts", "drizzle.config.ts", "db/**/*.ts", "logger/**/*.ts", "src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
