{
    "name": "anime-bot",
    "version": "1.5.0",
    "description": "",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "start": "bun run src/index.ts",
        "dev": "bun --watch src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun --packages external",
        "start:dist": "bun dist/index.js",
        "typecheck": "tsc --noEmit",
        "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
        "db:migrate": "bunx drizzle-kit migrate --config drizzle.config.ts",
        "db:push": "bunx drizzle-kit push --config drizzle.config.ts",
        "db:studio": "bunx drizzle-kit studio --config drizzle.config.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jarkurghan/anime-bot.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "engines": {
        "bun": ">=1.1.0"
    },
    "bugs": {
        "url": "https://github.com/jarkurghan/anime-bot/issues"
    },
    "homepage": "https://github.com/jarkurghan/anime-bot#readme",
    "dependencies": {
        "drizzle-orm": "^0.45.2",
        "grammy": "^1.41.1",
        "hono": "^4.12.9",
        "node-schedule": "^2.1.1",
        "pg": "^8.20.0"
    },
    "devDependencies": {
        "@types/bun": "^1.2.5",
        "@types/node": "^22.13.10",
        "@types/node-schedule": "^2.1.7",
        "@types/pg": "^8.11.11",
        "drizzle-kit": "^0.31.10",
        "typescript": "^5.8.2"
    }
}
