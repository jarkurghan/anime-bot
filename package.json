{
    "name": "anime-bot",
    "version": "1.4.0",
    "description": "",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx watch index.ts",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate --config drizzle.config.ts",
        "db:push": "drizzle-kit push --config drizzle.config.ts",
        "db:studio": "drizzle-kit studio --config drizzle.config.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jarkurghan/anime-bot.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "engines": {
        "node": ">=24.11.0",
        "npm": ">=11.6.0"
    },
    "bugs": {
        "url": "https://github.com/jarkurghan/anime-bot/issues"
    },
    "homepage": "https://github.com/jarkurghan/anime-bot#readme",
    "dependencies": {
        "dotenv": "^17.4.0",
        "drizzle-orm": "^0.45.2",
        "node-schedule": "^2.1.1",
        "nodemon": "^3.1.14",
        "pg": "^8.20.0",
        "telegraf": "^4.16.3"
    },
    "devDependencies": {
        "@types/node": "^22.13.10",
        "@types/node-schedule": "^2.1.7",
        "@types/pg": "^8.11.11",
        "drizzle-kit": "^0.31.10",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    },
    "nodemonConfig": {
        "ignore": [
            "drafts/*",
            "node_modules",
            "dist"
        ]
    }
}
